---
import Layout from '../../layouts/Layout.astro';
import CopyButton from '../../components/CopyButton.astro';
import PromptVariableForm from '../../components/PromptVariableForm.astro';
import { requireAuth, createSupabaseClient } from '../../lib/supabase';
import { getDepartmentLabel } from '../../lib/departments';
import type { Artifact, ArtifactVersion } from '../../lib/types';

const user = await requireAuth(Astro);
if (!user) return Astro.redirect('/login');

const { slug } = Astro.params;
const supabase = createSupabaseClient(Astro);

const { data: artifact, error } = await supabase
  .from('artifacts')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .single();

if (error || !artifact) return Astro.redirect('/');

const { data: versions } = await supabase
  .from('artifact_versions')
  .select('*')
  .eq('artifact_id', artifact.id)
  .order('version', { ascending: false });

const siteUrl = import.meta.env.PUBLIC_SITE_URL;

const typeLabels: Record<string, string> = {
  skill: 'Claude Code Skill',
  command: 'Slash Command',
  agent: 'Agent',
  prompt: 'Prompt Template',
  'web-skill': 'Claude.ai Web Skill',
};

const targetDirs: Record<string, string> = {
  skill: '~/.claude/skills/',
  command: '~/.claude/commands/',
  agent: '.claude/agents/',
};
---

<Layout title={artifact.title}>
  <div class="max-w-3xl">
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800 dark:bg-blue-900/30 dark:text-blue-400">
        {typeLabels[artifact.type] ?? artifact.type}
      </span>
      <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">
        {artifact.surface}
      </span>
      {artifact.department && (
        <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-400">
          {getDepartmentLabel(artifact.department)}
        </span>
      )}
    </div>

    <h1 class="text-2xl font-bold">{artifact.title}</h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">{artifact.description}</p>

    {artifact.tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {artifact.tags.map((tag: string) => (
          <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-500 dark:bg-gray-800 dark:text-gray-400">#{tag}</span>
        ))}
      </div>
    )}

    <p class="mt-3 text-xs text-gray-400 dark:text-gray-500">
      Published {artifact.published_at ? new Date(artifact.published_at).toLocaleDateString() : ''}
      &middot; {artifact.submitted_by}
    </p>

    <hr class="my-6 border-gray-200 dark:border-gray-800" />

    {artifact.type === 'prompt' ? (
      <PromptVariableForm
        content={artifact.content}
        variables={artifact.metadata?.variables ?? []}
      />
    ) : (
      <div class="relative">
        <pre class="overflow-x-auto rounded bg-gray-900 p-4 text-sm text-gray-100"><code>{artifact.content}</code></pre>
        <CopyButton content={artifact.content} />
      </div>
    )}

    {['skill', 'command', 'agent'].includes(artifact.type) && (
      <div class="mt-6 rounded border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-800/50">
        <h2 class="mb-2 text-sm font-semibold">Install via CLI</h2>
        <pre class="overflow-x-auto rounded bg-gray-900 px-3 py-2 text-sm text-gray-100"><code>curl -fsSL {siteUrl}/install.sh | sh -s -- {artifact.type} "{artifact.slug}"</code></pre>
        <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
          Installs to <code>{targetDirs[artifact.type]}</code>. Prompts before overwriting an
          existing file.
        </p>
      </div>
    )}

    {artifact.type === 'web-skill' && (
      <div class="mt-6 rounded border border-gray-200 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-800/50">
        <h2 class="mb-2 text-sm font-semibold">Setup instructions</h2>
        {artifact.metadata?.setup_steps && artifact.metadata.setup_steps.length > 0 ? (
          <ol class="list-inside list-decimal space-y-1 text-sm text-gray-700 dark:text-gray-300">
            {artifact.metadata.setup_steps.map((step: string) => <li>{step}</li>)}
          </ol>
        ) : (
          <p class="text-sm text-gray-500 dark:text-gray-400">No setup steps provided.</p>
        )}
        {artifact.metadata?.share_url && (
          <a
            href={artifact.metadata.share_url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-block rounded bg-blue-600 px-4 py-2 text-sm text-white hover:bg-blue-700"
          >
            Open in Claude.ai
          </a>
        )}
      </div>
    )}

    {versions && versions.length > 0 && (
      <div class="mt-8">
        <h2 class="mb-3 text-sm font-semibold">Version history</h2>
        <ul class="space-y-2 text-sm">
          {versions.map((v: ArtifactVersion) => (
            <li class="flex items-baseline gap-4">
              <span class="w-8 font-medium">v{v.version}</span>
              <span class="text-xs text-gray-400 dark:text-gray-500">{new Date(v.created_at).toLocaleDateString()}</span>
              {v.change_note && <span class="text-gray-600 dark:text-gray-400">{v.change_note}</span>}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Layout>
