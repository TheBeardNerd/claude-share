---
import Layout from '../../layouts/Layout.astro';
import { requireAuth, createServiceClient } from '../../lib/supabase';
import { getDepartmentLabel } from '../../lib/departments';
import type { Artifact, ReviewNote } from '../../lib/types';

const user = await requireAuth(Astro);
if (!user) return Astro.redirect('/login');

if (user.email !== import.meta.env.MAINTAINER_EMAIL) return Astro.redirect('/');

const supabase = createServiceClient();

const { data: pending } = await supabase
  .from('artifacts')
  .select('*, review_notes(*)')
  .eq('status', 'pending_review')
  .order('created_at', { ascending: true });

const submitterIds = [...new Set((pending ?? []).map((a) => a.submitter_user_id).filter(Boolean))];
const submitterEmails: Record<string, string> = {};
await Promise.all(
  submitterIds.map(async (id: string) => {
    const { data } = await supabase.auth.admin.getUserById(id);
    if (data?.user?.email) submitterEmails[id] = data.user.email;
  })
);
---

<Layout title="Review queue">
  <h1 class="mb-6 text-2xl font-bold">Review queue</h1>

  {(!pending || pending.length === 0) ? (
    <p class="text-sm text-gray-500 dark:text-gray-400">No submissions pending review.</p>
  ) : (
    <div class="space-y-6">
      {pending.map((artifact: Artifact & { review_notes: ReviewNote[] }) => (
        <div class="rounded border border-gray-200 bg-white p-5 dark:border-gray-700 dark:bg-gray-900">
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <span class="rounded bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
              {artifact.type}
            </span>
            <span class="text-xs text-gray-400 dark:text-gray-500">{artifact.surface}</span>
            {artifact.pii_flagged && (
              <span class="rounded bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 dark:bg-red-900/20 dark:text-red-400">
                PII flagged
              </span>
            )}
          </div>

          <h2 class="text-base font-semibold">{artifact.title}</h2>
          <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">{artifact.description}</p>
          <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
            {submitterEmails[artifact.submitter_user_id] ?? artifact.submitted_by} &middot; {getDepartmentLabel(artifact.department)} &middot; submitted{' '}
            {new Date(artifact.created_at).toLocaleDateString()}
          </p>

          <pre class="mt-4 overflow-x-auto rounded bg-gray-900 p-3 text-xs text-gray-100"><code>{artifact.content}</code></pre>

          <form
            method="post"
            action={`/api/review/${artifact.id}`}
            class="mt-4 flex flex-col gap-3"
          >
            <textarea
              name="note"
              rows={2}
              placeholder="Note to submitter (required for changes requested / rejected)"
              class="rounded border border-gray-300 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
            />
            <div class="flex gap-3">
              <button
                name="action"
                value="approved"
                class="rounded bg-green-600 px-4 py-2 text-sm text-white hover:bg-green-700"
              >
                Approve
              </button>
              <button
                name="action"
                value="changes_requested"
                class="rounded bg-yellow-500 px-4 py-2 text-sm text-white hover:bg-yellow-600"
              >
                Request changes
              </button>
              <button
                name="action"
                value="rejected"
                class="rounded bg-red-600 px-4 py-2 text-sm text-white hover:bg-red-700"
              >
                Reject
              </button>
            </div>
          </form>
        </div>
      ))}
    </div>
  )}
</Layout>
