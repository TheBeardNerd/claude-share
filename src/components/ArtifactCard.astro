---
import type { Artifact } from '../lib/types';
import { SURFACE_LABELS } from '../lib/types';

interface Props {
  artifact: Artifact;
}
const { artifact } = Astro.props;

const typeLabels: Record<string, string> = {
  skill: 'Skill',
  command: 'Command',
  agent: 'Agent',
  prompt: 'Prompt',
  'web-skill': 'Web Skill',
};
---

<a
  href={`/artifacts/${artifact.slug}`}
  class="block rounded border border-gray-200 bg-white p-4 transition-colors hover:border-blue-400 dark:border-gray-700 dark:bg-gray-900 dark:hover:border-blue-500"
>
  <div class="mb-2 flex items-center gap-2">
    <span class="rounded bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
      {typeLabels[artifact.type] ?? artifact.type}
    </span>
    <span class="text-xs text-gray-400 dark:text-gray-500">{SURFACE_LABELS[artifact.surface] ?? artifact.surface}</span>
  </div>
  <h2 class="text-sm font-semibold leading-snug">{artifact.title}</h2>
  <p class="mt-1 line-clamp-2 text-xs text-gray-500 dark:text-gray-400">{artifact.description}</p>
  {artifact.tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-1">
      {artifact.tags.slice(0, 3).map((tag: string) => (
        <span class="text-xs text-gray-400 dark:text-gray-500">#{tag}</span>
      ))}
    </div>
  )}
</a>
