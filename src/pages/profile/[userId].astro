---
import Layout from '../../layouts/Layout.astro';
import { requireAuth, createSupabaseClient } from '../../lib/supabase';
import { DEPARTMENTS, getDepartmentLabel } from '../../lib/departments';
import { gravatarUrl, displayName } from '../../lib/gravatar';
import { scanForPii } from '../../lib/pii-scan';
import type { Profile } from '../../lib/types';

const user = await requireAuth(Astro);
if (!user) return Astro.redirect('/login');

const { userId } = Astro.params;
const isOwnProfile = user.id === userId;
const supabase = createSupabaseClient(Astro);

const errors: string[] = [];

if (Astro.request.method === 'POST') {
  if (!isOwnProfile) {
    return new Response('Forbidden', { status: 403 });
  }

  const form = await Astro.request.formData();
  const first_name = String(form.get('first_name') ?? '').trim().slice(0, 100) || null;
  const last_name = String(form.get('last_name') ?? '').trim().slice(0, 100) || null;
  const department = String(form.get('department') ?? '').trim() || null;
  const bio = String(form.get('bio') ?? '').trim().slice(0, 500) || null;
  const avatar_url = gravatarUrl(user.email!, 200);

  if (bio) {
    const pii = scanForPii(bio);
    if (pii.flagged) {
      errors.push('Bio appears to contain sensitive information (email, phone, or credentials). Please remove it before saving.');
    }
  }

  if (errors.length > 0) {
    // fall through to re-render the form with errors
  } else {
  const { error } = await supabase.from('profiles').upsert({
    user_id: user.id,
    first_name,
    last_name,
    department,
    bio,
    avatar_url,
  });

  if (error) {
      errors.push('Failed to save profile. Please try again.');
    } else {
      return Astro.redirect(`/profile/${user.id}?saved=1`);
    }
  }
}

const saved = Astro.url.searchParams.get('saved') === '1';
// Keep edit form open if there were POST errors
const startEditing = errors.length > 0;

const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('user_id', userId)
  .single() as { data: Profile | null };

if (!profile && !isOwnProfile) {
  return new Response('Profile not found', { status: 404 });
}

const avatarSrc = profile?.avatar_url
  ?? (isOwnProfile ? gravatarUrl(user.email!, 200) : gravatarUrl(userId!, 200, true));

const name = displayName(profile?.first_name ?? null, profile?.last_name ?? null);
const hasName = name !== 'Unknown';
---

<Layout title={hasName ? name : 'Profile'}>
  <div class="mx-auto max-w-2xl">

    {saved && (
      <div class="mb-6 rounded border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 dark:border-green-800/50 dark:bg-green-900/20 dark:text-green-400">
        Profile saved.
      </div>
    )}

    {errors.length > 0 && (
      <ul class="mb-6 space-y-1 rounded border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800/50 dark:bg-red-900/20 dark:text-red-400">
        {errors.map((e) => <li>{e}</li>)}
      </ul>
    )}

    {/* Profile view */}
    <div id="profile-view">
      <div class="flex items-start gap-5">
        <img
          src={avatarSrc}
          alt={hasName ? name : 'Profile avatar'}
          width="80"
          height="80"
          class="size-20 shrink-0 rounded-full border border-gray-200 dark:border-gray-700"
        />
        <div class="min-w-0 flex-1 pt-1">
          <div class="flex items-start justify-between gap-4">
            <h1 class="text-xl font-bold">
              {hasName ? name : <span class="text-gray-400 dark:text-gray-500">No name set</span>}
            </h1>
            {isOwnProfile && (
              <button
                id="edit-btn"
                type="button"
                class="shrink-0 rounded border border-gray-300 px-3 py-1.5 text-sm text-gray-600 hover:border-gray-400 hover:text-gray-900 dark:border-gray-700 dark:text-gray-400 dark:hover:border-gray-500 dark:hover:text-gray-100"
              >
                Edit profile
              </button>
            )}
          </div>
          {profile?.department && (
            <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">
              {getDepartmentLabel(profile.department)}
            </p>
          )}
          {profile?.bio ? (
            <p class="mt-3 text-sm text-gray-700 dark:text-gray-300">{profile.bio}</p>
          ) : isOwnProfile ? (
            <p class="mt-3 text-sm italic text-gray-400 dark:text-gray-500">No bio yet.</p>
          ) : (
            <p class="mt-3 text-sm italic text-gray-400 dark:text-gray-500">No bio.</p>
          )}
        </div>
      </div>
    </div>

    {/* Edit form — own profile only, hidden until Edit is clicked */}
    {isOwnProfile && (
      <div id="profile-edit" class={startEditing ? '' : 'hidden'}>
        <form method="post" class="flex flex-col gap-4">
          <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold">Edit profile</h2>
            <button
              id="cancel-btn"
              type="button"
              class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
            >
              Cancel
            </button>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <label class="flex flex-col gap-1 text-sm font-medium">
              First name
              <input
                name="first_name"
                type="text"
                value={profile?.first_name ?? ''}
                autocomplete="given-name"
                maxlength={100}
                placeholder="e.g. Taylor"
                class="rounded border border-gray-300 bg-white px-3 py-2 text-sm font-normal focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
              />
            </label>

            <label class="flex flex-col gap-1 text-sm font-medium">
              Last name
              <input
                name="last_name"
                type="text"
                value={profile?.last_name ?? ''}
                autocomplete="family-name"
                maxlength={100}
                placeholder="e.g. Smith"
                class="rounded border border-gray-300 bg-white px-3 py-2 text-sm font-normal focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
              />
            </label>
          </div>

          <label class="flex flex-col gap-1 text-sm font-medium">
            Department
            <select
              name="department"
              class="w-64 rounded border border-gray-300 bg-white px-3 py-2 text-sm font-normal focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
            >
              <option value="">— Select department —</option>
              {DEPARTMENTS.map((d) => (
                <option value={d.slug} selected={profile?.department === d.slug}>{d.label}</option>
              ))}
            </select>
          </label>

          <label class="flex flex-col gap-1 text-sm font-medium">
            Bio
            <span class="font-normal text-xs text-gray-500 dark:text-gray-400">
              Optional · max 500 characters · do not include sensitive or personal information
            </span>
            <textarea
              name="bio"
              rows={4}
              maxlength={500}
              placeholder="A short description of what you work on or how you use Claude"
              class="rounded border border-gray-300 bg-white px-3 py-2 text-sm font-normal focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
            >{profile?.bio ?? ''}</textarea>
          </label>

          <p class="text-xs text-gray-500 dark:text-gray-400">
            Profile photo is pulled from <a href="https://gravatar.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-700 dark:hover:text-gray-300">Gravatar</a> using your work email.
          </p>

          <div class="flex items-center gap-3">
            <button
              type="submit"
              class="rounded bg-blue-600 px-4 py-2 text-sm text-white hover:bg-blue-700"
            >
              Save profile
            </button>
            <button
              type="button"
              id="cancel-btn-2"
              class="text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
            >
              Cancel
            </button>
          </div>
        </form>
      </div>
    )}
  </div>
</Layout>

{isOwnProfile && (
  <script>
    const view = document.getElementById('profile-view')!;
    const edit = document.getElementById('profile-edit')!;

    function showEdit() {
      view.classList.add('hidden');
      edit.classList.remove('hidden');
    }
    function showView() {
      edit.classList.add('hidden');
      view.classList.remove('hidden');
    }

    document.getElementById('edit-btn')?.addEventListener('click', showEdit);
    document.getElementById('cancel-btn')?.addEventListener('click', showView);
    document.getElementById('cancel-btn-2')?.addEventListener('click', showView);
  </script>
)}
