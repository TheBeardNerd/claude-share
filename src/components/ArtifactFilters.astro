---
import { DEPARTMENTS } from '../lib/departments';

interface Props {
  type: string;
  department: string;
  surface: string;
  sort: string;
}
const { type, department, surface, sort } = Astro.props;
---

<div class="flex flex-wrap gap-3">
  <select
    name="type"
    form="filter-form"
    onchange="this.form.submit()"
    class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
  >
    <option value="" selected={!type}>All types</option>
    <option value="skill" selected={type === 'skill'}>Skill</option>
    <option value="command" selected={type === 'command'}>Command</option>
    <option value="agent" selected={type === 'agent'}>Agent</option>
    <option value="prompt" selected={type === 'prompt'}>Prompt</option>
    <option value="web-skill" selected={type === 'web-skill'}>Web Skill</option>
  </select>

  <select
    name="department"
    form="filter-form"
    onchange="this.form.submit()"
    class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
  >
    <option value="" selected={!department}>All departments</option>
    {DEPARTMENTS.map((d) => (
      <option value={d.slug} selected={department === d.slug}>{d.label}</option>
    ))}
  </select>

  <select
    name="surface"
    form="filter-form"
    onchange="this.form.submit()"
    class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
  >
    <option value="" selected={!surface}>All surfaces</option>
    <option value="claude-code" selected={surface === 'claude-code'}>Claude Code</option>
    <option value="claude-ai" selected={surface === 'claude-ai'}>Claude.ai</option>
    <option value="all" selected={surface === 'all'}>All Surfaces</option>
  </select>

  <select
    name="sort"
    form="filter-form"
    onchange="this.form.submit()"
    class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100"
  >
    <option value="newest" selected={sort === 'newest'}>Newest</option>
    <option value="updated" selected={sort === 'updated'}>Recently updated</option>
  </select>
</div>
